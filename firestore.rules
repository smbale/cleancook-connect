rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'createdAt']) &&
             data.keys().size() <= 4 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'title', 'content', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10 && (data.tags.size() == 0 || (data.tags[0] is string && data.tags[0].size() <= 50))));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'text', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.authorId is string && data.authorId.size() <= 128 &&
             (!('postId' in data) || data.postId is string) &&
             (!('parentId' in data) || data.parentId is string) &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.text is string && data.text.size() <= 2000;
    }

    // Match blocks
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.displayName != null; // Secure list
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio']);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidPost(incoming()) && 
                    incoming().authorId == request.auth.uid &&
                    incoming().createdAt == request.time;
      allow update: if isEmailVerified() && (
        // Action: Edit post
        (isOwner(existing().authorId) && isValidPost(incoming()) && 
         incoming().authorId == existing().authorId &&
         incoming().createdAt == existing().createdAt &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'tags'])) ||
        // Action: Like post
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && 
         incoming().likesCount == existing().likesCount + 1)
      );
      allow delete: if isEmailVerified() && isOwner(existing().authorId);
    }

    match /posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidComment(incoming()) && 
                    incoming().authorId == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    exists(/databases/$(database)/documents/posts/$(postId));
      allow delete: if isEmailVerified() && isOwner(existing().authorId);
    }

    // Collection group rule for comments
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
  }
}
