{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "createdAt"]
    },
    "post": {
      "title": "Post",
      "description": "Forum post created by a user",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "tags": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" }
      },
      "required": ["authorId", "authorName", "title", "content", "createdAt"]
    },
    "comment": {
      "title": "Comment",
      "description": "Comment on a forum post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "post",
      "description": "Forum posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "comment",
      "description": "Comments nested under posts"
    }
  }
}
